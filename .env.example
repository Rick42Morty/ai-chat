# ─── Supabase ────────────────────────────────────────────────
# Secret key (formerly service_role) — SERVER ONLY, never expose to browser
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Publishable key (formerly anon) — used only for Realtime subscriptions in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ─── OpenAI ──────────────────────────────────────────────────
# SERVER ONLY — never prefix with NEXT_PUBLIC_
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# ─── Upload limits ───────────────────────────────────────────
MAX_IMAGE_SIZE_BYTES=5242880        # 5 MB
MAX_DOCUMENT_SIZE_BYTES=20971520    # 20 MB

